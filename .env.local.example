# LifeGuard AI 环境变量模版
# 复制此文件为 .env.local 并在其中填写真实的 Key

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI 供应商 API Keys
VITE_GEMINI_KEY=AIzaSy...
VITE_GROQ_KEY=gsk_...
VITE_SILICONFLOW_KEY=sk-...
VITE_VOYAGE_API_KEY=pa-...

# Gemini 模型配置
# 可选值: gemini-2.0-flash (默认), gemini-2.0-flash-lite, gemini-1.5-flash
# 如需使用 Gemini 2.5 Preview, 请设置为: gemini-2.5-flash-preview-04-17
VITE_GEMINI_MODEL=gemini-2.0-flash
